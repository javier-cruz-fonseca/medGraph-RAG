# Google Gemini API Key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=tu_api_key_aqui

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=tu_password_neo4j

# Modelos Gemini (opcional)
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# LM Studio (LLM local - alternativa a Azure)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=google/gemma-3-4b

# Azure OpenAI (alternativa a LM Studio + Gemini)
AZURE_OPENAI_API_KEY=tu_azure_api_key
AZURE_OPENAI_ENDPOINT=https://tu-recurso.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=tu-deployment-name
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=tu-embedding-deployment
# NOTE: Embeddings models may require different API versions
# Common versions: 2024-02-15-preview, 2023-12-01-preview, 2023-07-01-preview
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_EMBEDDINGS_API_VERSION=2024-02-15-preview
